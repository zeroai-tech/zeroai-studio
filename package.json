{
  "name": "zeroai-studio",
  "version": "0.3.0",
  "description": "ZeroAI Studio \u2014 install the STEM suite like Adobe Creative Cloud (pick what you want).",
  "author": "ZeroAI Technologies <support@zeroaitech.tech>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --publish never",
    "dist:full": "electron-builder --publish never -c.extraResources.0.from=bundled-apps -c.extraResources.0.to=bundled-apps",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:linux": "electron-builder --linux --publish never"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "adm-zip": "^0.5.17"
  },
  "build": {
    "appId": "tech.zeroai.studio",
    "productName": "ZeroAI Studio",
    "copyright": "\u00a9 ZeroAI Technologies",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "apps/**/*",
      "studio.config.json",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.education",
      "icon": "build/icon.png",
      "artifactName": "ZeroAI-Studio-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64",
            "ia32"
          ]
        }
      ],
      "icon": "build/icon.png",
      "artifactName": "ZeroAI-Studio-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Education",
      "artifactName": "ZeroAI-Studio-${version}-${arch}.${ext}"
    }
  }
}
